                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"expense\",\n    \"category\": \"Rent\",\n    \"amount\": 1500,\n    \"date\": \"2026-06-02T10:00:00.000Z\"\n}"
